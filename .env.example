# Copy this file to .env and fill in your actual API keys

# Generic API Keys - Configure based on your chosen services
# The server expects these generic environment variable names

# Local Stack Configuration
WHISPER_MODEL=tiny
OLLAMA_MODEL=phi3:mini
OLLAMA_BASE_URL=http://localhost:11434
LLM_TEMPERATURE=0.3
EDGE_TTS_VOICE=en-US-AriaNeural
EDGE_TTS_RATE=+0%
EDGE_TTS_VOLUME=+0%

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=true

# Logging Configuration
LOG_LEVEL=INFO